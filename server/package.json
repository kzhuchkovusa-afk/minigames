{
  "name": "kidsbrain-server",
  "version": "0.1.0",
  "private": true,
  "description": "KidsBrain platform backend — auth, children, games, scores",
  "main": "server.js",
  "type": "commonjs",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "db:init": "node db/init.js",
    "db:seed": "node db/seed.js",
    "db:reset": "node db/init.js --reset && node db/seed.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^11.3.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "jsonwebtoken": "^9.0.2"
  }
}
